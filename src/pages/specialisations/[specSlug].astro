---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IconBadge from "../../components/IconBadge.astro";
import { getSpecialisationBySlug, getSpecialisations } from "../../data/gameData";

export function getStaticPaths() {
  return getSpecialisations().map((specialisation) => ({
    params: { specSlug: specialisation.slug },
    props: { specialisation }
  }));
}

const { specialisation } = Astro.props;
const resolvedSpec = specialisation ?? getSpecialisationBySlug(Astro.params.specSlug ?? "");
const base = import.meta.env.BASE_URL;

if (!resolvedSpec) {
  throw new Error(`Missing specialisation for slug '${Astro.params.specSlug}'.`);
}
---

<BaseLayout title={`${resolvedSpec.displayName} | Arena Game`} description={resolvedSpec.description}>
  <Breadcrumbs
    items={[
      { href: base, label: "Home" },
      { href: `${base}classes/${resolvedSpec.classSlug}`, label: resolvedSpec.classDisplayName },
      { label: resolvedSpec.displayName }
    ]}
  />

  <section class="hero">
    <span class="eyebrow">Specialisation</span>
    <div class="card-title">
      <IconBadge name={resolvedSpec.displayName} />
      <div>
        <h1>{resolvedSpec.displayName}</h1>
        <div class="badge-row">
          <span class="badge">{resolvedSpec.classDisplayName}</span>
          <span class="badge">{resolvedSpec.role}</span>
          <span class="badge">{resolvedSpec.abilityPools.length} pools</span>
        </div>
        <p class="lede">{resolvedSpec.description}</p>
      </div>
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <h2>Ability Pools</h2>
        <p>Pool access and unlock requirements are resolved directly from the published bundle.</p>
      </div>
    </div>
    <div class="grid">
      {
        resolvedSpec.abilityPools.map((pool) => (
          <article class="pool-card">
            <div class="section-header" style="margin-top: 0;">
              <div>
                <h3>{pool.displayName}</h3>
                <p>{pool.description || "No description provided in the export."}</p>
              </div>
              <div class="badge-row">
                <span class="badge">{pool.totalPoints} points</span>
                <span class="badge">{pool.abilities.length} abilities</span>
              </div>
            </div>
            {pool.unlockRequirements.length > 0 ? (
              <div class="badge-row" style="margin-bottom: 0.9rem;">
                {pool.unlockRequirements.map((entry) => (
                  <span class="chip">{entry}</span>
                ))}
              </div>
            ) : null}
            <div class="grid cards">
              {pool.abilities.map((ability) => (
                <article class="ability-card">
                  <a href={`${base}abilities/${ability.routeKey}`}>
                    <h3>{ability.displayName}</h3>
                    <div class="badge-row">
                      <span class="chip">Level {ability.level}</span>
                      <span class="chip">{ability.loadoutKind}</span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
