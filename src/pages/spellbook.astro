---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import IconBadge from "../components/IconBadge.astro";
import { getPools } from "../data/gameData";

const pools = getPools().sort((left, right) => left.displayName.localeCompare(right.displayName));
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Spellbook | Arena Game" description="Browse Arena Game ability pools and the abilities inside them.">
  <Breadcrumbs items={[{ href: base, label: "Home" }, { label: "Spellbook" }]} />

  <section class="hero">
    <span class="eyebrow">Global Tome</span>
    <h1>The full spellbook, grouped by pool.</h1>
    <p class="lede">
      Shared pools are shown by default. Add class and specialisation pools from the filters when you want a wider view.
    </p>
    <div class="badge-row">
      <span class="badge">{pools.length} pools</span>
      <span class="badge">14 shared by default</span>
    </div>
  </section>

  <section class="search-panel panel">
    <label for="spellbook-search" class="muted">Search pools</label>
    <input id="spellbook-search" type="search" placeholder="Search by pool name, class, specialisation, or ability name" />
    <div class="badge-row" style="margin-top: 0.9rem;">
      <label class="chip" for="filter-shared">
        <input id="filter-shared" type="checkbox" data-filter-tag="Shared" checked style="margin: 0;" />
        Shared
      </label>
      <label class="chip" for="filter-class">
        <input id="filter-class" type="checkbox" data-filter-tag="Class" style="margin: 0;" />
        Class
      </label>
      <label class="chip" for="filter-specialisation">
        <input
          id="filter-specialisation"
          type="checkbox"
          data-filter-tag="Specialisation"
          style="margin: 0;"
        />
        Specialisation
      </label>
    </div>
  </section>

  <section>
    <div class="grid cards" id="spellbook-grid">
      {
        pools.map((pool) => {
          const searchText = [
            pool.displayName,
            pool.description,
            pool.tag,
            ...pool.abilities.map((ability) => `${ability.displayName} ${ability.description} ${ability.loadoutKind}`),
            ...pool.specialisations.map((entry) => `${entry.classDisplayName} ${entry.displayName}`)
          ]
            .join(" ")
            .toLowerCase();

          return (
            <article class="card" data-search={searchText} data-tag={pool.tag}>
              <a href={`${base}pools/${pool.routeKey}/`}>
                <div class="card-title">
                  <IconBadge name={pool.displayName} />
                  <div>
                    <h3>{pool.displayName}</h3>
                    <div class="badge-row">
                      <span class="chip">{pool.abilities.length} abilities</span>
                      <span class="chip">{pool.specialisations.length} specialisations</span>
                      <span class="chip">{pool.tag}</span>
                    </div>
                  </div>
                </div>
                <p>{pool.description || "Open this pool to browse its grouped abilities."}</p>
                <div class="badge-row">
                  {pool.specialisations.slice(0, 3).map((entry) => (
                    <span class="chip">
                      {entry.classDisplayName} / {entry.displayName}
                    </span>
                  ))}
                </div>
                <div class="badge-row">
                  {pool.abilities.slice(0, 3).map((ability) => (
                    <span class="chip">{ability.displayName}</span>
                  ))}
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </section>

  <script>
    const input = document.querySelector("#spellbook-search");
    const tagFilters = Array.from(document.querySelectorAll("[data-filter-tag]"));
    const cards = Array.from(document.querySelectorAll("#spellbook-grid [data-search]"));

    const applyFilters = () => {
      const query = String(input && "value" in input ? input.value : "").trim().toLowerCase();
      const selectedTags = new Set(
        tagFilters
          .filter((filter) => "checked" in filter && filter.checked)
          .map((filter) => filter.getAttribute("data-filter-tag") || "")
          .filter(Boolean)
      );

      for (const card of cards) {
        const haystack = card.getAttribute("data-search") || "";
        const tag = card.getAttribute("data-tag") || "";
        const matchesText = query.length === 0 || haystack.includes(query);
        const matchesTag = selectedTags.has(tag);
        card.toggleAttribute("hidden", !(matchesText && matchesTag));
      }
    };

    input?.addEventListener("input", applyFilters);
    for (const filter of tagFilters) {
      filter.addEventListener("change", applyFilters);
    }
    applyFilters();
  </script>
</BaseLayout>
