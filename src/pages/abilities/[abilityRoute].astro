---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IconBadge from "../../components/IconBadge.astro";
import { getAbilities, getAbilityByRouteKey, getBuffById, getDebuffById } from "../../data/gameData";

export function getStaticPaths() {
  return getAbilities().map((ability) => ({
    params: { abilityRoute: ability.routeKey },
    props: { ability }
  }));
}

const { ability } = Astro.props;
const resolvedAbility = ability ?? getAbilityByRouteKey(Astro.params.abilityRoute ?? "");
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
if (!resolvedAbility) {
  throw new Error(`Missing ability for route '${Astro.params.abilityRoute}'.`);
}

type ResolvedBuffEntry = {
  link: (typeof resolvedAbility.linkedBuffs)[number];
  detail: NonNullable<ReturnType<typeof getBuffById>>;
};

type ResolvedDebuffEntry = {
  link: (typeof resolvedAbility.linkedDebuffs)[number];
  detail: NonNullable<ReturnType<typeof getDebuffById>>;
};

const resolvedBuffs = resolvedAbility.linkedBuffs
  .map((entry) => ({ link: entry, detail: getBuffById(entry.id) }))
  .filter((entry): entry is ResolvedBuffEntry => entry.detail !== undefined);

const resolvedDebuffs = resolvedAbility.linkedDebuffs
  .map((entry) => ({ link: entry, detail: getDebuffById(entry.id) }))
  .filter((entry): entry is ResolvedDebuffEntry => entry.detail !== undefined);

const pool = resolvedAbility.poolMemberships[0];
---

<BaseLayout title={`${resolvedAbility.displayName} | Arena Game`} description={resolvedAbility.description}>
  <Breadcrumbs
    items={[
      { href: base, label: "Home" },
      { href: `${base}spellbook/`, label: "Spellbook" },
      ...(pool ? [{ href: `${base}pools/${pool.routeKey}/`, label: pool.displayName }] : []),
      { label: resolvedAbility.displayName }
    ]}
  />

  <section class="hero">
    <span class="eyebrow">Ability</span>
    <div class="card-title">
      <IconBadge name={resolvedAbility.displayName} icon={resolvedAbility.icon} />
      <div>
        <h1>{resolvedAbility.displayName}</h1>
        <div class="badge-row">
          {resolvedAbility.isAutoAttack ? (
            <span class="badge">Auto Attack</span>
          ) : (
            <span class="badge">Level {resolvedAbility.level}</span>
          )}
          {pool ? <span class="badge">{pool.displayName}</span> : null}
          {resolvedAbility.categoryNames.map((categoryName) => (
            <span class="chip">{categoryName}</span>
          ))}
        </div>
        <p class="lede">{resolvedAbility.description || "Core attack behavior exported from the Arena Game data bundle."}</p>
      </div>
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <h2>Combat Data</h2>
        <p>Core ability details surfaced from the bundle.</p>
      </div>
    </div>
    <div class="detail-grid">
      <section>
        <h3>Output & Damage</h3>
        <ul class="list-reset">
          {resolvedAbility.outputSummary.map((entry) => <li>{entry}</li>)}
          {resolvedAbility.damageSummary.map((entry) => <li>{entry}</li>)}
        </ul>
      </section>
      <section>
        <h3>Timing</h3>
        <ul class="list-reset">
          {resolvedAbility.timingSummary.map((entry) => <li>{entry}</li>)}
        </ul>
      </section>
      <section>
        <h3>Resource</h3>
        <ul class="list-reset">
          {resolvedAbility.resourceSummary.map((entry) => <li>{entry}</li>)}
        </ul>
      </section>
      <section>
        <h3>Targeting</h3>
        <ul class="list-reset">
          {resolvedAbility.targetingSummary.map((entry) => <li>{entry}</li>)}
        </ul>
      </section>
    </div>
  </section>

  <section>
    <div class="section-header">
      <div>
        <h2>Applies</h2>
        <p>Buffs and debuffs applied by this ability.</p>
      </div>
    </div>
    {resolvedBuffs.length > 0 || resolvedDebuffs.length > 0 ? (
      <div class="grid cards">
        {resolvedBuffs.map(({ link, detail }) => (
          <article class="card">
            <a href={`${base}abilities/${resolvedAbility.routeKey}/buffs/${detail.routeKey}/`}>
              <div class="card-title">
                <IconBadge name={detail.displayName} icon={detail.icon} />
                <div>
                  <h3>{detail.displayName}</h3>
                  <p>{detail.description}</p>
                </div>
              </div>
              <div class="badge-row">
                <span class="chip">Buff</span>
                <span class="chip">{link.statusType}</span>
                <span class="chip">Duration {link.duration}</span>
                <span class="chip">{link.reapplication}</span>
                <span class="chip">Base Duration {detail.baseDuration}</span>
              </div>
              <p>Value: {link.value} | Tick: {link.tickInterval} | Removable: {link.isRemovable ? "Yes" : "No"}</p>
              {detail.behaviors.length > 0 ? (
                <ul class="list-reset">
                  {detail.behaviors.map((behavior) => <li>{behavior.effectType}: {behavior.value}</li>)}
                </ul>
              ) : null}
            </a>
          </article>
        ))}
        {resolvedDebuffs.map(({ link, detail }) => (
          <article class="card">
            <a href={`${base}abilities/${resolvedAbility.routeKey}/debuffs/${detail.routeKey}/`}>
              <div class="card-title">
                <IconBadge name={detail.displayName} icon={detail.icon} />
                <div>
                  <h3>{detail.displayName}</h3>
                  <p>{detail.description}</p>
                </div>
              </div>
              <div class="badge-row">
                <span class="chip">Debuff</span>
                <span class="chip">{link.statusType}</span>
                <span class="chip">Duration {link.duration}</span>
                <span class="chip">{link.reapplication}</span>
                <span class="chip">Base Duration {detail.baseDuration}</span>
              </div>
              <p>Value: {link.value} | Tick: {link.tickInterval} | Removable: {link.isRemovable ? "Yes" : "No"}</p>
              {detail.categoryNames.length > 0 ? <p>Categories: {detail.categoryNames.join(", ")}</p> : null}
              {detail.breakThreshold ? <p>Break Threshold: {detail.breakThreshold}</p> : null}
              {detail.behaviors.length > 0 ? (
                <ul class="list-reset">
                  {detail.behaviors.map((behavior) => <li>{behavior.effectType}: {behavior.value}</li>)}
                </ul>
              ) : null}
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="panel" style="padding: 1rem;">
        <p>No buffs or debuffs linked to this ability in the export.</p>
      </div>
    )}
  </section>

  {resolvedAbility.triggeredAbilities.length > 0 ? (
    <section>
      <div class="section-header">
        <div>
          <h2>Triggered Abilities</h2>
          <p>Related ability definitions referenced by this ability, including trap and proc effects.</p>
        </div>
      </div>
      <div class="grid cards">
        {resolvedAbility.triggeredAbilities.map((triggeredAbility) => (
          <article class="card">
            <a href={`${base}abilities/${triggeredAbility.routeKey}/`}>
              <div class="card-title">
                <IconBadge name={triggeredAbility.displayName} icon={triggeredAbility.icon} />
                <div>
                  <h3>{triggeredAbility.displayName}</h3>
                  <p>{triggeredAbility.description}</p>
                </div>
              </div>
              <div class="badge-row">
                <span class="chip">{triggeredAbility.relation}</span>
                {triggeredAbility.isAutoAttack ? (
                  <span class="chip">Auto Attack</span>
                ) : (
                  <>
                    <span class="chip">Level {triggeredAbility.level}</span>
                    <span class="chip">{triggeredAbility.loadoutKind}</span>
                  </>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  ) : null}

  <section>
    <div class="section-header">
      <div>
        <h2>Available To</h2>
        <p>Specialisations that can access this ability.</p>
      </div>
    </div>
    <div class="grid cards">
      {
        resolvedAbility.specialisationLinks.map((spec) => (
          <article class="card">
            <a href={`${base}specialisations/${spec.slug}/`}>
              <div class="card-title">
                <IconBadge name={spec.displayName} icon={spec.icon} />
                <div>
                  <h3>{spec.displayName}</h3>
                  <div class="badge-row">
                    <span class="chip">{spec.classDisplayName}</span>
                  </div>
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
