---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Arena Game class, specialisation, ability, buff, and debuff reference." } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        --bg: #f4efe5;
        --panel: rgba(255, 250, 242, 0.82);
        --panel-strong: #fff9f1;
        --ink: #1e1a17;
        --muted: #61564d;
        --accent: #9a3412;
        --accent-2: #1d4ed8;
        --line: rgba(64, 42, 26, 0.14);
        --shadow: 0 24px 60px rgba(56, 35, 20, 0.12);
        --radius: 24px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(251, 191, 36, 0.18), transparent 28rem),
          radial-gradient(circle at top right, rgba(29, 78, 216, 0.12), transparent 26rem),
          linear-gradient(180deg, #f8f3ea 0%, #efe4d3 100%);
        font-family: Georgia, "Times New Roman", serif;
        min-height: 100vh;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1160px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.25rem 0 4rem;
      }

      .site-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 1.1rem 1.25rem;
        margin: 1rem 0 2rem;
        background: rgba(255, 249, 241, 0.68);
        border: 1px solid var(--line);
        border-radius: 999px;
        backdrop-filter: blur(12px);
        box-shadow: var(--shadow);
      }

      .brand {
        text-decoration: none;
      }

      .brand-mark {
        display: block;
        letter-spacing: 0.18em;
        font-size: 0.72rem;
        text-transform: uppercase;
        color: var(--accent);
      }

      .brand-name {
        display: block;
        font-size: 1.15rem;
        font-weight: 700;
      }

      .nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .nav a {
        text-decoration: none;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid transparent;
        color: var(--muted);
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--ink);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.7);
      }

      .hero,
      .panel,
      .card,
      .stat-grid > div,
      .detail-grid > section,
      .status-card,
      .ability-card,
      .pool-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }

      .hero {
        padding: 2rem;
        margin-bottom: 1.75rem;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 0.85rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(154, 52, 18, 0.12);
        color: var(--accent);
      }

      h1,
      h2,
      h3 {
        margin: 0 0 0.75rem;
        line-height: 1.05;
      }

      h1 {
        font-size: clamp(2.4rem, 6vw, 4.8rem);
      }

      h2 {
        font-size: clamp(1.6rem, 3vw, 2.5rem);
      }

      h3 {
        font-size: 1.2rem;
      }

      p {
        color: var(--muted);
        line-height: 1.65;
      }

      .lede {
        font-size: 1.06rem;
        max-width: 68ch;
      }

      .cta-row,
      .badge-row,
      .breadcrumb,
      .meta-list {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button,
      .badge,
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        text-decoration: none;
      }

      .button {
        padding: 0.7rem 1rem;
        background: var(--ink);
        color: #fff8ee;
      }

      .button.secondary {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--ink);
      }

      .badge,
      .chip {
        padding: 0.4rem 0.7rem;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.55);
        color: var(--muted);
        font-size: 0.9rem;
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .grid.cards {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      }

      .card,
      .ability-card,
      .pool-card,
      .status-card {
        padding: 1.2rem;
      }

      .card a,
      .ability-card a,
      .pool-card a,
      .status-card a {
        text-decoration: none;
      }

      .card-title {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }

      .icon-badge {
        width: 3rem;
        height: 3rem;
        border-radius: 16px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        background:
          linear-gradient(135deg, rgba(154, 52, 18, 0.92), rgba(29, 78, 216, 0.72));
        color: #fff8ee;
        font-size: 1.25rem;
        font-weight: 700;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        margin: 2.25rem 0 1rem;
      }

      .stat-grid,
      .detail-grid {
        display: grid;
        gap: 1rem;
      }

      .stat-grid {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .stat-grid > div,
      .detail-grid > section {
        padding: 1rem;
      }

      .stat-grid dt,
      .detail-grid h3 {
        color: var(--muted);
      }

      .stat-grid dd {
        margin: 0.3rem 0 0;
        font-size: 1.15rem;
        font-weight: 700;
      }

      .detail-grid {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .list-reset {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .list-reset li + li {
        margin-top: 0.6rem;
      }

      .muted {
        color: var(--muted);
      }

      .breadcrumb {
        margin-bottom: 1rem;
      }

      .breadcrumb a {
        color: var(--accent-2);
      }

      .search-panel {
        padding: 1rem;
        margin-bottom: 1.25rem;
      }

      .search-panel input {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.76);
        color: var(--ink);
        font: inherit;
      }

      .site-footer {
        margin-top: 3rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 1rem, 1160px);
        }

        .hero {
          padding: 1.35rem;
        }

        .site-header {
          border-radius: 28px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={base}>
          <span class="brand-mark">Arena Game Data</span>
          <span class="brand-name">Class Tome</span>
        </a>
        <nav class="nav" aria-label="Main navigation">
          <a href={base}>Home</a>
          <a href={`${base}spellbook`}>Spellbook</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built from Unity-exported gameplay data for informational reference.</p>
      </footer>
    </div>
  </body>
</html>
