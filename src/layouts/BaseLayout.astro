---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Arena Game class, specialisation, ability, buff, and debuff reference." } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        const storedTheme = localStorage.getItem("arena-theme");
        const theme = storedTheme === "dark" ? "dark" : "light";
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <style is:global>
      :root {
        --bg-start: #f6f7f8;
        --bg-end: #e7e9ed;
        --bg-glow-1: rgba(255, 255, 255, 0.9);
        --bg-glow-2: rgba(17, 24, 39, 0.08);
        --panel: rgba(255, 255, 255, 0.8);
        --panel-strong: rgba(255, 255, 255, 0.94);
        --ink: #111318;
        --muted: #525866;
        --accent: #0f172a;
        --accent-2: #334155;
        --line: rgba(15, 23, 42, 0.12);
        --shadow: 0 24px 72px rgba(15, 23, 42, 0.12);
        --radius: 22px;
      }

      :root[data-theme="dark"] {
        --bg-start: #111318;
        --bg-end: #090a0d;
        --bg-glow-1: rgba(255, 255, 255, 0.08);
        --bg-glow-2: rgba(255, 255, 255, 0.04);
        --panel: rgba(19, 21, 26, 0.86);
        --panel-strong: rgba(26, 29, 35, 0.94);
        --ink: #f3f4f6;
        --muted: #a1a1aa;
        --accent: #fafafa;
        --accent-2: #d4d4d8;
        --line: rgba(255, 255, 255, 0.12);
        --shadow: 0 24px 72px rgba(0, 0, 0, 0.42);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, var(--bg-glow-1), transparent 28rem),
          radial-gradient(circle at top right, var(--bg-glow-2), transparent 22rem),
          linear-gradient(180deg, var(--bg-start) 0%, var(--bg-end) 100%);
        font-family: "Avenir Next", Avenir, "Segoe UI", sans-serif;
        min-height: 100vh;
        transition: background 180ms ease, color 180ms ease;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1160px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.25rem 0 4rem;
      }

      .site-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 0.95rem 1.1rem;
        margin: 1rem 0 2rem;
        background: var(--panel-strong);
        border: 1px solid var(--line);
        border-radius: 999px;
        backdrop-filter: blur(18px);
        box-shadow: var(--shadow);
      }

      .brand {
        text-decoration: none;
      }

      .brand-mark {
        display: block;
        letter-spacing: 0.18em;
        font-size: 0.72rem;
        text-transform: uppercase;
        color: var(--accent);
        opacity: 0.78;
      }

      .brand-name {
        display: block;
        font-size: 1.15rem;
        font-weight: 600;
      }

      .nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .nav a {
        text-decoration: none;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        color: var(--muted);
        background: rgba(255, 255, 255, 0.03);
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--ink);
        border-color: var(--line);
        background: rgba(255, 255, 255, 0.08);
      }

      :root:not([data-theme="dark"]) .nav a:hover,
      :root:not([data-theme="dark"]) .nav a:focus-visible {
        background: rgba(15, 23, 42, 0.06);
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .theme-toggle {
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
        font: inherit;
        cursor: pointer;
      }

      :root:not([data-theme="dark"]) .theme-toggle {
        background: rgba(15, 23, 42, 0.03);
      }

      .theme-toggle:hover,
      .theme-toggle:focus-visible {
        color: var(--ink);
      }

      .hero,
      .panel,
      .card,
      .stat-grid > div,
      .detail-grid > section,
      .status-card,
      .ability-card,
      .pool-card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }

      .hero {
        padding: 2rem;
        margin-bottom: 1.75rem;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
          var(--panel);
      }

      .hero--home h1 {
        max-width: 10ch;
        font-size: clamp(2.15rem, 4vw, 3.6rem);
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 0.85rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.06);
        color: var(--accent);
      }

      h1,
      h2,
      h3 {
        margin: 0 0 0.75rem;
        line-height: 1.05;
      }

      h1 {
        font-size: clamp(2.3rem, 5vw, 4.25rem);
        letter-spacing: -0.04em;
      }

      h2 {
        font-size: clamp(1.6rem, 3vw, 2.5rem);
      }

      h3 {
        font-size: 1.2rem;
      }

      p {
        color: var(--muted);
        line-height: 1.65;
      }

      .lede {
        font-size: 1.06rem;
        max-width: 68ch;
      }

      .cta-row,
      .badge-row,
      .breadcrumb,
      .meta-list {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .button,
      .badge,
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border-radius: 999px;
        text-decoration: none;
      }

      .button {
        padding: 0.7rem 1rem;
        background: var(--ink);
        color: var(--panel-strong);
        font-weight: 600;
      }

      .button.secondary {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--ink);
      }

      .badge,
      .chip {
        padding: 0.4rem 0.7rem;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted);
        font-size: 0.9rem;
      }

      :root:not([data-theme="dark"]) .badge,
      :root:not([data-theme="dark"]) .chip,
      :root:not([data-theme="dark"]) .nav a,
      :root:not([data-theme="dark"]) .search-panel input {
        background: rgba(15, 23, 42, 0.03);
      }

      .grid {
        display: grid;
        gap: 1rem;
      }

      .grid.cards {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      }

      .card,
      .ability-card,
      .pool-card,
      .status-card {
        padding: 1.2rem;
      }

      .card a,
      .ability-card a,
      .pool-card a,
      .status-card a {
        text-decoration: none;
      }

      .card-title {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }

      .icon-badge {
        width: 3rem;
        height: 3rem;
        border-radius: 16px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.06));
        color: var(--ink);
        font-size: 1.25rem;
        font-weight: 700;
        object-fit: cover;
        overflow: hidden;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        margin: 2.25rem 0 1rem;
      }

      .stat-grid,
      .detail-grid {
        display: grid;
        gap: 1rem;
      }

      .stat-grid {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .stat-grid > div,
      .detail-grid > section {
        padding: 1rem;
      }

      .stat-grid dt,
      .detail-grid h3 {
        color: var(--muted);
      }

      .stat-grid dd {
        margin: 0.3rem 0 0;
        font-size: 1.15rem;
        font-weight: 700;
      }

      .detail-grid {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }

      .list-reset {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .list-reset li + li {
        margin-top: 0.6rem;
      }

      .muted {
        color: var(--muted);
      }

      .breadcrumb {
        margin-bottom: 1rem;
      }

      .breadcrumb a {
        color: var(--accent-2);
      }

      .search-panel {
        padding: 1rem;
        margin-bottom: 1.25rem;
      }

      .search-panel input {
        width: 100%;
        padding: 0.85rem 1rem;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.05);
        color: var(--ink);
        font: inherit;
      }

      .site-footer {
        margin-top: 3rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line);
        color: var(--muted);
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100% - 1rem, 1160px);
        }

        .hero {
          padding: 1.35rem;
        }

      .site-header {
          border-radius: 28px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={base}>
          <span class="brand-mark">Arena Game Data</span>
          <span class="brand-name">Class Tome</span>
        </a>
        <div class="header-actions">
          <nav class="nav" aria-label="Main navigation">
            <a href={base}>Home</a>
            <a href={`${base}classes/`}>Classes</a>
            <a href={`${base}spellbook/`}>Spellbook</a>
          </nav>
          <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>Dark mode</button>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>Built from Unity-exported gameplay data for informational reference.</p>
      </footer>
    </div>
    <script is:inline>
      const themeToggle = document.querySelector("[data-theme-toggle]");

      const syncThemeToggle = () => {
        if (!(themeToggle instanceof HTMLButtonElement)) {
          return;
        }

        const isDark = document.documentElement.dataset.theme === "dark";
        themeToggle.textContent = isDark ? "Light mode" : "Dark mode";
        themeToggle.setAttribute("aria-pressed", String(isDark));
      };

      themeToggle?.addEventListener("click", () => {
        const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = nextTheme;
        localStorage.setItem("arena-theme", nextTheme);
        syncThemeToggle();
      });

      syncThemeToggle();
    </script>
  </body>
</html>
